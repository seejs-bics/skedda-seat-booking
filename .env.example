# Skedda Seat Booking — Configuration
# For GitHub Actions: set these as repository secrets.
# For local testing: copy to .env and fill in your values.

# Your Skedda venue URL (no trailing slash)
SKEDDA_URL=https://yourcompany.skedda.com

# Login credentials
SKEDDA_EMAIL=your.email@company.com
SKEDDA_PASS=your_password_here

# Priority-ordered seat list — "name:space_id,name:space_id,..."
# The script tries the first seat; if taken, falls back to the next.
# To find space IDs, see the README.
SEAT_PRIORITY=GEMS 1:1281271,DOM 2:1273200,GEMS 5:1281275

# Venue ID (found in Skedda's /webs API response)
VENUE_ID=202392

# Booking time window (24-hour format)
BOOKING_START=09:00
BOOKING_END=18:00

# How many days ahead to book
DAYS_AHEAD=12

# Days of week to book: 0=Mon,1=Tue,2=Wed,3=Thu,4=Fri,5=Sat,6=Sun
BOOKING_DAYS=0,3,4

# Timezone
TIMEZONE=Asia/Singapore

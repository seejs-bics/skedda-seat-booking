# ============================================================
# Skedda Seat Booking — Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# Your Skedda venue URL (no trailing slash)
# Example: https://yourcompany.skedda.com
SKEDDA_URL=https://yourcompany.skedda.com

# Login credentials
SKEDDA_EMAIL=your.email@company.com
SKEDDA_PASS=your_password_here

# Exact name of the seat/space as shown in Skedda's booking map
# Tip: hover over the seat in Skedda to see its exact label
SEAT_NAME=Desk 12

# Daily booking time window (24-hour format)
BOOKING_START=09:00
BOOKING_END=18:00

# How many days ahead to book (Skedda opens bookings this many days in advance)
DAYS_AHEAD=12
